{
  "name": "elementary-audio-kit",
  "version": "0.3.0",
  "description": "Musical abstractions for Elementary Audio - timing, sequencing, and instruments",
  "author": "Ricardo Abreu",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./timing": {
      "types": "./dist/timing/index.d.ts",
      "import": "./dist/timing/index.js",
      "require": "./dist/timing/index.cjs"
    },
    "./sequencing": {
      "types": "./dist/sequencing/index.d.ts",
      "import": "./dist/sequencing/index.js",
      "require": "./dist/sequencing/index.cjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "audio",
    "dsp",
    "elementary",
    "music",
    "sequencer",
    "synthesizer",
    "timing",
    "transport"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ricardoabreu/elementary-audio-kit.git"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest",
    "ladle": "ladle serve",
    "ladle:build": "ladle build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@elemaudio/core": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "lucide-react": ">=0.300.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@elemaudio/core": "^4.0.3",
    "@elemaudio/offline-renderer": "^4.0.3",
    "@elemaudio/web-renderer": "^4.0.3",
    "@ladle/react": "^5.1.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8.57.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
